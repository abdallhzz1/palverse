APP_NAME="Palverse API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.palverse.example.com
APP_TIMEZONE=UTC
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# API Versioning and Release
PALVERSE_API_VERSION=1.0.0
PALVERSE_RELEASE=

# Security & CORS
PALVERSE_ALLOWED_ORIGINS=https://palverse.example.com,https://admin.palverse.example.com

# Frontend App URLs
PALVERSE_PUBLIC_WEB_URL=https://palverse.example.com
PALVERSE_ADMIN_WEB_URL=https://admin.palverse.example.com
PALVERSE_FRONTEND_RESET_PASSWORD_URL=https://palverse.example.com/reset-password
PALVERSE_FRONTEND_VERIFY_EMAIL_URL=https://palverse.example.com/verify-email

# Logging (Strict for Production)
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=14

# Database Config
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=palverse_prod
DB_USERNAME=palverse_user
DB_PASSWORD=secret

# Cache, Queue, Session Config
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Redis Config
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Config
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@palverse.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Storage Config
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=palverse-production
AWS_USE_PATH_STYLE_ENDPOINT=false

# Palverse App Settings
PALVERSE_SEED_DEMO_DATA=false
PALVERSE_DEMO_PASSWORD=
PALVERSE_SUBSCRIPTION_EXPIRING_DAYS=7
PALVERSE_MAX_UPLOAD_SIZE_KB=5120
PALVERSE_TOKEN_EXPIRATION_MINUTES=1440
PALVERSE_AUDIT_RETENTION_DAYS=90
PALVERSE_REFERENCE_CACHE_TTL_SECONDS=3600
PALVERSE_BOOTSTRAP_CACHE_TTL_SECONDS=300
