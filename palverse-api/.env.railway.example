APP_NAME="Palverse API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR-API.up.railway.app
APP_TIMEZONE=Asia/Jerusalem
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

PALVERSE_API_VERSION=1.0.0

# After Vercel deploy, replace with real URLs
PALVERSE_ALLOWED_ORIGINS=https://YOUR-WEB.vercel.app,https://YOUR-ADMIN.vercel.app
PALVERSE_PUBLIC_WEB_URL=https://YOUR-WEB.vercel.app
PALVERSE_ADMIN_WEB_URL=https://YOUR-ADMIN.vercel.app
PALVERSE_FRONTEND_RESET_PASSWORD_URL=https://YOUR-WEB.vercel.app/reset-password
PALVERSE_FRONTEND_VERIFY_EMAIL_URL=https://YOUR-WEB.vercel.app/verify-email

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Linked from Railway MySQL service (map these in Variables)
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# Free-tier friendly (no Redis required)
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@palverse.demo"
MAIL_FROM_NAME="Palverse"

# Demo seed once on first boot, then set to false and redeploy
PALVERSE_ALLOW_DEMO_SEEDING=true
PALVERSE_SEED_DEMO_ON_BOOT=true
PALVERSE_DEMO_ADMIN_PASSWORD=DemoAdmin123!
PALVERSE_DEMO_MERCHANT_PASSWORD=DemoMerchant123!
PALVERSE_DEMO_CUSTOMER_PASSWORD=DemoCustomer123!
PALVERSE_DEMO_REPRESENTATIVE_PASSWORD=DemoRepresentative123!
PALVERSE_DEMO_FOLLOWUP_PASSWORD=DemoFollowUp123!
PALVERSE_DEMO_FOLLOW_UP_PASSWORD=DemoFollowUp123!
